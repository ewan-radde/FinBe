import pandas as pd
import numpy as np

df = pd.read_csv("data/E2_24-25.csv")

odds = df[["HomeTeam","AwayTeam","FTHG","FTAG","PSCH","PSCD","PSCA"]].copy()
odds = odds.dropna(subset=["PSCH","PSCD","PSCA"]).reset_index(drop=True)

# raw implied probabilities (inflated by margin)
odds["imp_home"] = 1 / odds["PSCH"]
odds["imp_draw"] = 1 / odds["PSCD"]
odds["imp_away"] = 1 / odds["PSCA"]
odds["overround"] = odds["imp_home"] + odds["imp_draw"] + odds["imp_away"]

print(f"Matches: {len(odds)}")
print(f"Average overround: {odds['overround'].mean():.4f}")
odds[["PSCH","PSCD","PSCA","imp_home","imp_draw","imp_away","overround"]].head()


print("FTHG missing:", df["FTHG"].isna().sum())
print("PSCH missing:", df["PSCH"].isna().sum())
print("Total rows in file:", len(df))
print("Date range:", pd.to_datetime(df["Date"], dayfirst=True).min(), "to", pd.to_datetime(df["Date"], dayfirst=True).max())


# METHOD 1: Equal margin — just divide each raw prob by the overround
odds["eq_home"] = odds["imp_home"] / odds["overround"]
odds["eq_draw"] = odds["imp_draw"] / odds["overround"]
odds["eq_away"] = odds["imp_away"] / odds["overround"]

# METHOD 2: Margin proportional to odds (Buchdahl's original)
# fair odds O_f = n*O / (n - M*O), where n=3 outcomes, M = margin, O = bookmaker odds
M = odds["overround"] - 1          # the margin per match
n = 3

def fair_odds(O, M):
    return (n * O) / (n - M * O)

# apply to each outcome's ODDS, then convert back to probability
odds["pr_home"] = 1 / fair_odds(odds["PSCH"], M)
odds["pr_draw"] = 1 / fair_odds(odds["PSCD"], M)
odds["pr_away"] = 1 / fair_odds(odds["PSCA"], M)

# check both methods now sum to ~1.0
odds["eq_sum"] = odds["eq_home"] + odds["eq_draw"] + odds["eq_away"]
odds["pr_sum"] = odds["pr_home"] + odds["pr_draw"] + odds["pr_away"]

print("Equal method sum (should be 1.0):", odds["eq_sum"].mean().round(5))
print("Proportional method sum (should be ~1.0):", odds["pr_sum"].mean().round(5))
odds[["PSCH","PSCD","PSCA","eq_home","pr_home","eq_away","pr_away"]].head()



